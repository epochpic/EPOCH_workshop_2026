begin:control
  nx = 8
  nsteps = 0
  x_min = 0
  x_max = 8
end:control

begin:boundaries
  bc_x_min = open
  bc_x_max = open
end:boundaries

begin:species
  name = Electron
  charge = -1.0
  mass = 1.0
  nparticles = nx * 1000
  density = if ((x gt 2) and (x lt 6), 100, 0) 
end:species

begin:output
  number_density = always
end:output

